{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "skipLibCheck": false,
    "types": [
      "vitest/globals",
      "node",
      "@testing-library/jest-dom/vitest"
    ]
  },
  "include": [
    "next-env.d.ts",
    "vitest.setup.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ],
  "exclude": [
    ".next",
    "node_modules"
  ]
}
